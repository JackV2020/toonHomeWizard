      if ('batteryActive' in userSettingsJSON ) { batteryActive = userSettingsJSON['batteryActive'] }
      if ('batteryVisible' in userSettingsJSON ) { batteryVisible = userSettingsJSON['batteryVisible'] }
      if ('batterykWhColumn' in userSettingsJSON ) { batterykWhColumn = userSettingsJSON['batterykWhColumn'] }
      if ('batteryKWHImportYesterday' in userSettingsJSON ) { batteryKWHImportYesterday = userSettingsJSON['batteryKWHImportYesterday'] }
      if ('batteryKWHImportLastWeek' in userSettingsJSON ) { batteryKWHImportLastWeek = userSettingsJSON['batteryKWHImportLastWeek'] }
